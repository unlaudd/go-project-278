:{$PORT:8080} {
    # 📦 Раздаём статику фронтенда
    root * /app/frontend/dist
    file_server

    # 🔁 Проксируем API и редиректы на бэкенд
    reverse_proxy /api/* {$BACKEND_HOST:localhost}:{$BACKEND_PORT:9000}
    reverse_proxy /r/* {$BACKEND_HOST:localhost}:{$BACKEND_PORT:9000}

    # 🪪 CORS (опционально, но полезно)
    header {
        +Access-Control-Allow-Origin *
        +Access-Control-Allow-Methods GET,POST,PUT,DELETE,OPTIONS
        +Access-Control-Allow-Headers Content-Type,Accept
        +Access-Control-Expose-Headers Content-Range
    }
}